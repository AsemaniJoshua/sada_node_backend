// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  // binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

// User model for authentication and authorization
model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  role            Role              @default(user)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]
}

// RefreshToken model for token management
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @db.LongText
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// PasswordReset model for OTP-based password reset
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  otpHash   String
  isVerified Boolean @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Home model - Singleton page for statistics and featured projects
model Home {
  id               String   @id @default(uuid())
  statistics       Json // [{ label, value }]
  featuredProjects Json // [{ id, title, description, image: { url, public_id } }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Hero model - Hero banner with image and call-to-action
model Hero {
  id         String     @id @default(uuid())
  title      String
  subtitle   String
  image      Json       // { url, public_id }
  label      String
  target_url String
  status     HeroStatus @default(draft)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// About model - Singleton page for mission, vision, and organization details
model About {
  id         String   @id @default(uuid())
  mission    String   @db.LongText
  vision     String   @db.LongText
  coreValues Json // [string]
  history    String   @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Membership model - Member registration and management
model Membership {
  id                    String               @id @default(uuid())
  firstName             String
  lastName              String
  dob                   String               // "1990-05-15" format
  age                   Int
  placeOfBirth          String
  gender                String               // male, female, other
  hometown              String
  currentAddress        String
  ethnicity             String
  suburb                String
  occupation            String
  phone                 String               @unique
  email                 String               @unique
  fatherName            String
  fatherHometown        String
  fatherContact         String
  motherName            String
  motherHometown        String
  motherContact         String
  emergencyName         String
  emergencyRelationship String
  emergencyOccupation   String
  emergencyContact      String
  declaration           Boolean              @default(true)
  status                MembershipStatus     @default(pending)
  notes                 String?              @db.LongText // Private notes for admin only
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

// Enum for membership status
enum MembershipStatus {
  pending
  approved
  rejected
}

// Project model - Showcase projects with multiple images
model Project {
  id          String        @id @default(uuid())
  title       String
  description String        @db.LongText
  status      ProjectStatus @default(completed)
  images      Json // [{ url, public_id }]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// BlogPost model - Blog articles with content and images
model BlogPost {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  author    String
  date      DateTime @default(now())
  images    Json     // [{ url, public_id }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Gallery model - Photo gallery with multiple images per entry
model Gallery {
  id        String   @id @default(uuid())
  title     String
  images    Json     // [{ url, public_id }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact model - Form submissions from website visitors (append-only)
model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.LongText
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Testimonial model - Customer/user testimonials with image
model Testimonial {
  id        String               @id @default(uuid())
  name      String
  role      String
  text      String               @db.LongText
  image     Json                 // { url, public_id }
  ratings   Int                 // 1-5 rating scale
  status    TestimonialStatus    @default(draft)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

// FAQ model - Frequently asked questions
model FAQ {
  id        String    @id @default(uuid())
  question  String
  answer    String    @db.LongText
  category  String
  status    FAQStatus @default(draft)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Journey model - Timeline of organizational milestones
model Journey {
  id          String        @id @default(uuid())
  year        String
  title       String
  description String        @db.LongText
  category    String
  status      JourneyStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Announcement model - News feed/announcements
model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Leadership {
  id          String            @id @default(uuid())
  name        String
  role        String
  email       String            @unique
  bio         String            @db.LongText
  image       Json
  start_year  String
  end_year    String?
  social_media Json?             // { linkedin, twitter, instagram, etc. }
  status      LeadershipStatus  @default(draft)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Payment {
  id             String   @id @default(uuid())
  memberId       String
  amount         Decimal  @db.Decimal(10, 2)
  amountWithFee  Decimal  @db.Decimal(10, 2)
  purpose        String
  status         PaymentStatus @default(pending)
  reference      String   @unique
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Enum for payment status
enum PaymentStatus {
  pending
  successful
  failed
}

// Enum for FAQ status
enum FAQStatus {
  published
  draft
}

// Enum for testimonial status
enum TestimonialStatus {
  published
  draft
}

// Enum for journey status
enum JourneyStatus {
  published
  draft
}

// Enum for hero status
enum HeroStatus {
  published
  draft
}

// Enum for leadership status
enum LeadershipStatus {
  published
  draft
}

// Enum for membership status
// enum MembershipStatus {
//   pending
//   approved
//   rejected
// }

// Enum for project status
enum ProjectStatus {
  planning
  active
  completed
  on_hold
}

// Enum for user roles
enum Role {
  admin
  user
}
