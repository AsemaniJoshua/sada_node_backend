// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  // binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model for authentication and authorization
model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  image             Json?
  role              Role               @default(user)
  isFirstTimeLogin  Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  activities        UserActivity[]
  pushSubscriptions PushSubscription[]
  notifications     Notification[]
  communicationLogs CommunicationLog[]
}

// PushSubscription model - stores browser push credentials
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Notification model - stores administrative alerts/notifications
model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  url       String?
  icon      String?
  isRead    Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// CommunicationLog model - stores history of bulk emails and SMS sent
model CommunicationLog {
  id             String            @id @default(uuid())
  type           CommunicationType
  target         String // e.g. "all_approved", "specific_member"
  recipientCount Int
  subject        String? // For emails only
  message        String            @db.LongText
  adminId        String
  admin          User              @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
}

enum CommunicationType {
  email
  sms
}

// UserActivity model - audit log for all admin mutations
model UserActivity {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      ActivityAction
  logType     ActivityLogType
  entity      String // e.g. "BlogPost", "Hero", "Membership"
  entityId    String? // ID of the affected record
  description String          @db.LongText // Human-readable summary
  metadata    Json? // Optional extra context (title, name, status, etc.)
  createdAt   DateTime        @default(now())
}

// RefreshToken model for token management
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @db.LongText
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// PasswordReset model for OTP-based password reset
model PasswordReset {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp        String
  otpHash    String
  isVerified Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Home model - Singleton page for statistics and featured projects
model Home {
  id               String   @id @default(uuid())
  statistics       Json // [{ label, value }]
  featuredProjects Json // [{ id, title, description, image: { url, public_id } }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Hero model - Hero banner with image and call-to-action
model Hero {
  id         String     @id @default(uuid())
  title      String
  subtitle   String
  image      Json // { url, public_id }
  label      String
  target_url String
  status     HeroStatus @default(draft)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// About model - Singleton page for mission, vision, and organization details
model About {
  id         String   @id @default(uuid())
  mission    String   @db.LongText
  vision     String   @db.LongText
  coreValues Json // [string]
  history    String   @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Membership model - Member registration and management
model Membership {
  id                    String           @id @default(uuid())
  memberId              String           @unique @default("TEMP")
  firstName             String
  lastName              String
  dob                   String // "1990-05-15" format
  age                   Int
  placeOfBirth          String
  gender                String // male, female, other
  hometown              String
  currentAddress        String
  ethnicity             String
  suburb                String
  occupation            String
  phone                 String           @unique
  email                 String           @unique
  fatherName            String
  fatherHometown        String
  fatherContact         String
  motherName            String
  motherHometown        String
  motherContact         String
  emergencyName         String
  emergencyRelationship String
  emergencyOccupation   String
  emergencyContact      String
  declaration           Boolean          @default(true)
  status                MembershipStatus @default(pending)
  notes                 String?          @db.LongText // Private notes for admin only
  payments              Payment[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

// Enum for membership status
enum MembershipStatus {
  pending
  approved
  rejected
}

// Project model - Showcase projects with multiple images
model Project {
  id          String        @id @default(uuid())
  title       String
  description String        @db.LongText
  budget      Float
  category    String
  progress    Int // percentage 0-100
  status      ProjectStatus @default(planned)
  isFeatured  Boolean       @default(false)
  start_date  DateTime
  end_date    DateTime?
  images      Json // [{ url, public_id }]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// BlogPost model - Blog articles with content and images
model BlogPost {
  id        String           @id @default(uuid())
  title     String
  content   String           @db.LongText
  category  BlogPostCategory
  status    BlogPostStatus   @default(draft)
  tags      Json // ["tag1", "tag2"]
  images    Json // [{ url, public_id }]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// Gallery model - Photo gallery with multiple images per entry
model Gallery {
  id            String   @id @default(uuid())
  title         String
  description   String   @db.LongText
  primary_image Json // { url, public_id }
  event_date    DateTime
  category      String
  images        Json // [{ url, public_id }] - related photos
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Contact model - Form submissions from website visitors (append-only)
model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.LongText
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Testimonial model - Customer/user testimonials with image
model Testimonial {
  id        String            @id @default(uuid())
  name      String
  role      String
  text      String            @db.LongText
  image     Json // { url, public_id }
  ratings   Int // 1-5 rating scale
  status    TestimonialStatus @default(draft)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// FAQ model - Frequently asked questions
model FAQ {
  id        String    @id @default(uuid())
  question  String
  answer    String    @db.LongText
  category  String
  status    FAQStatus @default(draft)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Journey model - Timeline of organizational milestones
model Journey {
  id          String        @id @default(uuid())
  year        String
  title       String
  description String        @db.LongText
  category    String
  status      JourneyStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Announcement model - News feed/announcements
model Announcement {
  id          String               @id @default(uuid())
  title       String
  content     String               @db.LongText
  priority    AnnouncementPriority @default(low)
  status      AnnouncementStatus   @default(draft)
  start_date  DateTime
  expiry_date DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Leadership {
  id           String           @id @default(uuid())
  name         String
  role         String
  email        String           @unique
  bio          String           @db.LongText
  image        Json
  start_year   String
  end_year     String?
  social_media Json? // { linkedin, twitter, instagram, etc. }
  status       LeadershipStatus @default(draft)
  sort_order   Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Event model - Events with date, time and status management
model Event {
  id           String      @id @default(uuid())
  title        String
  event_type   String
  location     String
  description  String      @db.LongText
  event_banner Json // { url, public_id }
  start_date   DateTime
  start_time   String // Format: HH:MM (24-hour)
  status       EventStatus @default(draft)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Payment {
  id              String         @id @default(uuid())
  membership      Membership     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId        String
  uniqueMemberId  String?
  full_name       String
  email           String
  membership_role MembershipRole
  month_paid_for  Int // 1-12
  year_paid_for   Int
  amount          Decimal        @db.Decimal(10, 2)
  amountWithFee   Decimal        @db.Decimal(10, 2)
  payment_method  String?
  status          PaymentStatus  @default(pending)
  reference       String         @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Enum for membership role
enum MembershipRole {
  standard
  executive
  voluntary
}

// Enum for payment status
enum PaymentStatus {
  pending
  successful
  failed
}

// Enum for FAQ status
enum FAQStatus {
  published
  draft
}

// Enum for testimonial status
enum TestimonialStatus {
  published
  draft
}

// Enum for journey status
enum JourneyStatus {
  published
  draft
}

// Enum for hero status
enum HeroStatus {
  published
  draft
}

// Enum for leadership status
enum LeadershipStatus {
  published
  draft
}

// Enum for announcement priority
enum AnnouncementPriority {
  low
  medium
  high
}

// Enum for announcement status
enum AnnouncementStatus {
  published
  draft
}

// Enum for blog post category
enum BlogPostCategory {
  news
  blog
  article
}

// Enum for blog post status
enum BlogPostStatus {
  published
  draft
}

// Enum for membership status
// enum MembershipStatus {
//   pending
//   approved
//   rejected
// }

// Enum for project status
enum ProjectStatus {
  planned
  in_progress
  paused
  completed
  cancelled
}

// Enum for event status
enum EventStatus {
  draft
  upcoming
  live
  past
  cancelled
}

// Enum for user roles
enum Role {
  admin
  user
}

// Enum for activity log action types
enum ActivityAction {
  create
  update
  delete
  approve
  reject
}

// Enum for activity log category (used for filtering)
enum ActivityLogType {
  Auth
  Users
  Blog
  Gallery
  Events
  Projects
  Membership
  Payments
  Hero
  Announcements
  FAQs
  Journey
  Leadership
  Testimonials
  Contact
  Home
  About
}
