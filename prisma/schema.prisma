// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  // binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

// User model for authentication and authorization
model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  role            Role              @default(user)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]
}

// RefreshToken model for token management
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @db.LongText
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// PasswordReset model for OTP-based password reset
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  otpHash   String
  isVerified Boolean @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Home model - Singleton page for hero, statistics, and featured projects
model Home {
  id               String   @id @default(uuid())
  hero             Json // { title, subtitle, image: { url, public_id } }
  statistics       Json // [{ label, value }]
  featuredProjects Json // [{ id, title, description, image: { url, public_id } }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// About model - Singleton page for mission, vision, and organization details
model About {
  id         String   @id @default(uuid())
  mission    String   @db.LongText
  vision     String   @db.LongText
  coreValues Json // [string]
  history    String   @db.LongText
  membership Json // { benefits: [string], requirements: [string] }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Project model - Showcase projects with multiple images
model Project {
  id          String        @id @default(uuid())
  title       String
  description String        @db.LongText
  status      ProjectStatus @default(completed)
  images      Json // [{ url, public_id }]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// BlogPost model - Blog articles with content and images
model BlogPost {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  author    String
  date      DateTime @default(now())
  images    Json     // [{ url, public_id }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Gallery model - Photo gallery with multiple images per entry
model Gallery {
  id        String   @id @default(uuid())
  title     String
  images    Json     // [{ url, public_id }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact model - Form submissions from website visitors (append-only)
model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.LongText
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Testimonial model - Customer/user testimonials with image
model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  text      String   @db.LongText
  image     Json     // { url, public_id }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// FAQ model - Frequently asked questions
model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journey model - Timeline of organizational milestones
model Journey {
  id        String   @id @default(uuid())
  year      String
  event     String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Announcement model - News feed/announcements
model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Leadership {
  id        String   @id @default(uuid())
  name      String
  position  String
  bio       String   @db.LongText
  image     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id             String   @id @default(uuid())
  memberId       String
  amount         Decimal  @db.Decimal(10, 2)
  amountWithFee  Decimal  @db.Decimal(10, 2)
  purpose        String
  status         PaymentStatus @default(pending)
  reference      String   @unique
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Enum for payment status
enum PaymentStatus {
  pending
  successful
  failed
}

// Enum for project status
enum ProjectStatus {
  planning
  active
  completed
  on_hold
}

// Enum for user roles
enum Role {
  admin
  user
}
